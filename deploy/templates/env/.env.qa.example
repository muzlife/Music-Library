# QA runtime
APP_HOST=127.0.0.1
APP_PORT=8100
APP_RELOAD=0

# Runtime paths
LIBRARY_DB_PATH=/Users/__USER__/apps/__PROJECT_SLUG__-qa/runtime/data/library.db

# External access auth
LIBRARY_AUTH_COOKIE_SECURE=1
LIBRARY_ADMIN_USERNAME=
LIBRARY_ADMIN_PASSWORD=change-me
LIBRARY_OPERATOR_USERNAME=
LIBRARY_OPERATOR_PASSWORD=change-me
LIBRARY_AUTH_SESSION_SECRET=change-me-qa-session-secret
LIBRARY_PURCHASE_IMPORT_TOKEN=change-me-qa-import-token

# Metadata providers
DISCOGS_TOKEN=
ALADIN_TTB_KEY=
ALADIN_BASE_URL=https://www.aladin.co.kr/ttb/api/ItemSearch.aspx
MANIADB_BASE_URL=http://www.maniadb.com
DISCOGS_USER_AGENT=__PROJECT_SLUG__-library/1.0 (contact: qa@example.com)
MUSICBRAINZ_USER_AGENT=__PROJECT_SLUG__-library/1.0 (contact: qa@example.com)

# Optional offsite backup (preferred: Google Drive synced folder)
GOOGLE_DRIVE_BACKUP_DIR=

# Optional advanced offsite backup (Google Cloud Storage)
GCS_BACKUP_PREFIX=
GSUTIL_BIN=gsutil

# Matching thresholds
MATCH_CONFIDENCE_AUTO_APPROVE=0.90
MATCH_CONFIDENCE_REVIEW=0.60

# Optional QA helper accounts
QA_OPERATOR_USERNAME=
QA_OPERATOR_PASSWORD=change-me
QA_OPERATOR_FALLBACK_USERNAME=
QA_OPERATOR_FALLBACK_PASSWORD=change-me
