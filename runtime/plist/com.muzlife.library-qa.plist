  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/__USER__/apps/hahahoho-qa/runtime/logs/launchd.qa.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/__USER__/apps/hahahoho-qa/runtime/logs/launchd.qa.stderr.log</string>
