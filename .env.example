# Music Library Management Console — Environment Variables
# Copy this file to .env.local (QA/Dev) or .env (Prod) and fill in the values.
# NEVER commit real secrets!

# --- Database ---
LIBRARY_DB_PATH=data/library.db

# --- Discogs API ---
# Get a token at https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# --- Aladin API ---
# Get a TTB key at https://www.aladin.co.kr/ttb/wblog_manage.aspx
ALADIN_TTB_KEY=

# --- DeepL API (optional, for translation) ---
DEEPL_AUTH_KEY=

# --- DeepSeek API (optional) ---
DEEPSEEK_API_KEY=

# --- Auth ---
LIBRARY_ADMIN_USERNAME=
LIBRARY_ADMIN_PASSWORD=
LIBRARY_OPERATOR_USERNAME=
LIBRARY_OPERATOR_PASSWORD=
LIBRARY_OPERATOR_ACCOUNTS=
LIBRARY_AUTH_SESSION_SECRET=

# --- Purchase Import Webhook ---
LIBRARY_PURCHASE_IMPORT_TOKEN=

# --- Home Assistant (optional, for office climate widget) ---
HOME_ASSISTANT_BASE_URL=
HOME_ASSISTANT_TOKEN=
OFFICE_CLIMATE_TEMPERATURE_ENTITY_ID=
OFFICE_CLIMATE_HUMIDITY_ENTITY_ID=

# --- Spotify (optional) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8100/spotify/callback
